NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
# ホスト Ollama のみ（http://localhost:11434）。compose / 他 experiment の Ollama コンテナは使わない
OLLAMA_BASE_URL=http://localhost:11434
# LLM: gemma2:2b（Ollama 公式 library。理由は README 参照）
OLLAMA_LLM_MODEL=gemma2:2b
# Part2 だけ別モデルにしたい場合（未設定なら OLLAMA_LLM_MODEL を使用）
# OLLAMA_GRAPHITI_MODEL=gemma2:2b
# Graphiti 推奨 max_tokens（Ollama では遅くなる場合あり → OLLAMA_GRAPHITI_MAX_TOKENS=2048 で短縮可）
OLLAMA_GRAPHITI_MAX_TOKENS=16384
# 埋め込み: Part2 Graphiti に必須（ollama pull nomic-embed-text）
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_DIM=768
GRAPHITI_STRUCTURED_OUTPUT_MODE=json_schema
OLLAMA_DISABLE_THINKING=true
# 1 にすると Graphiti/Neo4j の詳細ログを表示（デフォルトは結果のみ）
# DEMO_VERBOSE=1
